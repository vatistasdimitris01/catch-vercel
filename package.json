{
  "name": "catch-vercel",
  "version": "2.0.0",
  "description": "CATCH — snag source from any Vercel deployment",
  "type": "module",
  "bin": {
    "vercel-deploy-source-downloader": "./dist/tui/cli.js"
  },
  "scripts": {
    "dev": "tsx src/tui/cli.tsx",
    "start": "node dist/tui/cli.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
